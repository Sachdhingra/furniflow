                        <div class="form-group"><label class="form-label">Password</label><input type="password" id="loginPassword" class="input" placeholder="Enter your password"></div>
                        <button onclick="handleLogin()" class="btn btn-primary" style="width:100%;">Sign In</button>
                        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #3A3A5C;font-size:0.65rem;color:#9CA3AF;text-align:center;line-height:1.8;">
                            Admin: john@admin123 | Sales: sarah@sales123<br>Service: mike@service123 | Field: tom@agent123<br>Site: raj@site123
                        </div>
                    </div>
                </div>
            </div>`;
        }

        function handleLogin() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const user = store.users.find(u => u.email === email && u.password === password && u.active);
            if (user) { store.currentUser = user; syncOfflineData(); logActivity('Login', 'User logged in'); currentPage = 'dashboard'; render(); }
            else { alert('Invalid credentials or inactive account'); }
        }

        function logout() { logActivity('Logout', 'User logged out'); store.currentUser = null; currentPage = 'login'; render(); }
        function navigate(page) { currentPage = page; render(); }

        function renderPage() {
            const pages = { 
                dashboard: renderDashboard, 
                leads: renderLeads, 
                services: renderServices,
                claims: renderClaims,
                jobs: renderJobs,
                siteVisits: renderSiteVisits,
                calendar: renderCalendar, 
                admin: renderAdmin, 
                users: renderUserManagement,
                reports: renderReports
            };
            return pages[currentPage]?.() || renderDashboard();
        }

