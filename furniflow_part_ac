        }

        function saveOffline(type, data) {
            offlineData.push({ type, data, timestamp: new Date().toISOString() });
            localStorage.setItem('furniflow_offline', JSON.stringify(offlineData));
        }

        function loadOfflineData() {
            const saved = localStorage.getItem('furniflow_offline');
            if (saved) offlineData = JSON.parse(saved);
        }

        function render() {
            loadOfflineData();
            const app = document.getElementById('app');
            if (!store.currentUser) { app.innerHTML = renderLogin(); initFlatpickr(); return; }
            
            const flashNotif = showFlashAlert ? store.notifications.find(n => n.isFlash && !n.read && (n.userId === 'all' || n.userId === 'all_' + store.currentUser.role)) : null;
            app.innerHTML = (flashNotif ? `<div class="flash-alert" onclick="dismissFlash()"><i class="fas fa-bell"></i> ${flashNotif.message}</div>` : '') + renderLayout(renderPage());
            initFlatpickr();
            if (flashNotif) { flashNotif.read = true; setTimeout(() => { showFlashAlert = false; render(); }, 10000); }
        }

        function dismissFlash() { showFlashAlert = false; render(); }

        function renderLogin() {
            return `<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;background:linear-gradient(135deg,#0F0F1A,#1A1A2E);">
                <div style="max-width:24rem;width:100%;">
