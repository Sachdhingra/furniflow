        function renderJobs() {
            const user = store.currentUser;
            let filteredJobs = store.jobs.filter(j => { 
                if (user.role === 'field_agent') return j.assignedTo === user.id; 
                return true; 
            });
            
            if (jobFilter === 'today') filteredJobs = filteredJobs.filter(j => j.scheduledDate === new Date().toISOString().split('T')[0]);
            else if (jobFilter === 'upcoming') filteredJobs = filteredJobs.filter(j => j.scheduledDate && !isOverdue(j.scheduledDate) && j.scheduledDate > new Date().toISOString().split('T')[0]);
            else if (jobFilter === 'overdue') filteredJobs = filteredJobs.filter(j => j.scheduledDate && isOverdue(j.scheduledDate) && !['completed','incomplete'].includes(j.status));
            
            return `<div style="display:grid;gap:1.5rem;">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
                    <div><h1 style="font-size:1.5rem;font-weight:700;color:white;">Jobs</h1><p style="color:#9CA3AF;">Service job management</p></div>
                    ${(user.role === 'service_head' || user.role === 'admin') ? `<button onclick="openJobModal()" class="btn btn-primary"><i class="fas fa-plus"></i> Add Job</button>` : ''}
                </div>
                
                <div class="filter-bar">
                    <button class="tab-btn ${jobFilter === 'all' ? 'active' : ''}" onclick="jobFilter='all';render()">All</button>
