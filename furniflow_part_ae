                    <button class="tab-btn ${jobFilter === 'upcoming' ? 'active' : ''}" onclick="jobFilter='upcoming';render()">Upcoming</button>
                    <button class="tab-btn ${jobFilter === 'overdue' ? 'active' : ''}" onclick="jobFilter='overdue';render()">Overdue</button>
                </div>
                
                <div class="card" style="padding:0;overflow-x:auto;">
                    <table class="table"><thead><tr><th>Customer</th><th>Type</th><th>Scheduled</th><th>Status</th><th>Assigned</th><th>Actions</th></tr></thead>
                        <tbody>${filteredJobs.map(j => `<tr>
                            <td><p style="color:white;font-weight:500;">${j.customerName}</p><p style="color:#9CA3AF;font-size:0.7rem;">${j.phone}</p>${j.status !== 'completed' && j.status !== 'incomplete' ? `<a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(j.address)}" target="_blank" class="map-link" style="margin-top:0.25rem;"><i class="fas fa-map-marker-alt"></i> Map</a>` : ''}</td>
                            <td><span class="badge badge-${j.jobType === 'delivery' ? 'converted' : j.jobType === 'installation' ? 'interested' : 'assigned'}">${j.jobType}</span></td>
                            <td>${j.scheduledDate ? `<span class="badge ${isOverdue(j.scheduledDate) && !['completed','incomplete'].includes(j.status) ? 'badge-overdue' : ''}">${formatDate(j.scheduledDate)}</span>` : '-'}</td>
                            <td><span class="badge badge-${j.status}">${j.status.replace('_', ' ')}</span></td>
                            <td>${j.assignedTo ? store.users.find(u => u.id === j.assignedTo)?.name : '-'}</td>
                            <td><div style="display:flex;gap:0.375rem;flex-wrap:wrap;">
                                ${(user.role === 'service_head' || user.role === 'admin') && !j.assignedTo ? `<button onclick="assignJob('${j.id}')" class="btn btn-secondary" style="padding:0.25rem 0.5rem;font-size:0.7rem;">Assign</button>` : ''}
                                ${user.role === 'field_agent' && j.status === 'assigned' ? `<button onclick="acceptJob('${j.id}')" class="btn btn-primary" style="padding:0.25rem 0.5rem;font-size:0.7rem;">Accept & Start</button>` : ''}
