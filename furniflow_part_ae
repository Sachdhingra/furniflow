                                ${user.role === 'field_agent' && j.status === 'in_progress' ? `<button onclick="reachedLocation('${j.id}')" class="btn btn-success" style="padding:0.25rem 0.5rem;font-size:0.7rem;">Reached</button>` : ''}
                                ${user.role === 'field_agent' && j.status === 'reached' ? `<button onclick="completeJob('${j.id}')" class="btn btn-success" style="padding:0.25rem 0.5rem;font-size:0.7rem;">Complete</button>` : ''}
                            </div></td>
                        </tr>`).join('') || '<tr><td colspan="6" style="text-align:center;color:#9CA3AF;padding:2rem;">No jobs</td></tr>'}</tbody></table>
                </div>
                
                ${filteredJobs.filter(j => !['completed','incomplete','created'].includes(j.status)).map(j => `<div class="card" style="margin-top:1rem;"><h4 style="color:white;font-weight:600;margin-bottom:0.75rem;">${j.customerName} - Timeline</h4><div class="timeline"><div class="timeline-item"><p style="color:#9CA3AF;font-size:0.75rem;">Created</p><p style="color:white;">${formatDateTime(j.createdAt)}</p></div>${j.acceptedAt ? `<div class="timeline-item completed"><p style="color:#9CA3AF;font-size:0.75rem;">Accepted/Started</p><p style="color:#00D9A5;">${formatDateTime(j.acceptedAt)}</p></div>` : ''}${j.travelStartAt ? `<div class="timeline-item completed"><p style="color:#9CA3AF;font-size:0.75rem;">Travel Started</p><p style="color:#FBBF24;">${formatDateTime(j.travelStartAt)}</p></div>` : ''}${j.reachedAt ? `<div class="timeline-item completed"><p style="color:#9CA3AF;font-size:0.75rem;">Reached</p><p style="color:#00D9A5;">${formatDateTime(j.reachedAt)}</p></div>` : ''}${j.completedAt ? `<div class="timeline-item completed"><p style="color:#9CA3AF;font-size:0.75rem;">Completed</p><p style="color:#86EFAC;">${formatDateTime(j.completedAt)}</p></div>` : ''}</div></div>`).join('')}</div>`;
        }

